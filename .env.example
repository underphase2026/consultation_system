# App
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# JWT Reset Token (비밀번호 재설정용 단기 토큰)
JWT_RESET_SECRET=your-reset-secret-key
JWT_RESET_EXPIRES_IN=10m

# Public Data API (공공데이터포털)
PUBLIC_DATA_API_KEY=your-public-data-api-key

# Database
DB_HOST=localhost
DB_PORT=3308
DB_USERNAME=root
DB_PASSWORD=1234
DB_DATABASE=underphase_db
